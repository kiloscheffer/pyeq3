class Polynomial_UserCustomizablePolynomial
{
	double Polynomial_UserCustomizablePolynomial_model(double x_in)
	{
		double temp;
		temp = 0.0;

		// coefficients
		double a = -3.6330887435333636E+00;
		double b = 3.2554318889398082E-01;
		double c = 7.8197144606992480E-02;

		temp += a * Math.pow(x_in, 0);
		temp += b * Math.pow(x_in, 1);
		temp += c * Math.pow(x_in, 2);
		return temp;
	}
