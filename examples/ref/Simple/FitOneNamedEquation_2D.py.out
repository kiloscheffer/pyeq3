import java.lang.Math;

// Fitting target: lowest sum of squared absolute error
// Fitting target value = 0.14401559057593963

class BioScience_HyperbolicLogistic
{
	double BioScience_HyperbolicLogistic_model(double x_in)
	{
		double temp;
		temp = 0.0;

		// coefficients
		double a = 1.0033641580019371E+01;
		double b = 6.0007984269861030E+00;
		double c = 3.7795567595208518E+05;

		temp = (a * Math.pow(x_in, b)) / (c + Math.pow(x_in, b));
		return temp;
	}
}

