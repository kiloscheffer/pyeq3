// If there are any errors or problems with this
// code output please raise an issue on GitHub:
// github.com/equations-project/pyeq3

import java.lang.Math;

// Fitting target: lowest sum of squared absolute error
// Fitting target value = 0.2595107129336552

class Polynomial_SimplifiedQuadratic
{
	double Polynomial_SimplifiedQuadratic_model(double x_in, double y_in)
	{
		double temp;
		temp = 0.0;

		// coefficients
		double a = 1.0888951874546766E+01;
		double b = -1.4494952645258785E+00;
		double c = -6.6615110081932025E+00;
		double d = 1.2017154114049904E-01;
		double f = 1.4957787062503742E+00;

		temp = a;
		temp += b * x_in;
		temp += c * y_in;
		temp += d * Math.pow(x_in, 2.0);
		temp += f * Math.pow(y_in, 2.0);
		return temp;
	}
}

